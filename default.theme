ThemeAuthor=                            "dibof228"
ThemeDescription=                       "WinBasic"

Look=                                   "flat"
Gradients=                              "buttonA.xpm buttonI.xpm"

#Buttons
RolloverButtonsSupported=               1
TitleButtonsSupported=                  "xmis"
TitleButtonsLeft=                       "s"
TitleButtonsRight=                      "xmi"

TaskBarClockLeds=                       1
TrayDrawBevel=                          0

#Borders
BorderSizeX=                            9
BorderSizeY=                            9
DlgBorderSizeX=                         9
DlgBorderSizeY=                         9
CornerSizeX=                            24
CornerSizeY=                            24
TitleBarHeight=                         21
TitleBarJustify=                        0
TitleBarVertOffset=                     0
ScrollBarX=                             16
ScrollBarY=                             16

#Icons
MenuIconSize=                           16
SmallIconSize=                          16
LargeIconSize=                          32
HugeIconSize=                           48

#DialogBox

ColorDialog=                            "rgb:f0/f0/f0"
ColorDialogSelectionText=               "rgb:ff/ff/ff"

#Taskbar
TaskbuttonIconOffset=                   10
ColorDefaultTaskBar=                    "rgb:81/94/AA"
